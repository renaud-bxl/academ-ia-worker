{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Academ-IA Node",
  "version": "1.0.1",
  "identifier": "com.academ-ia.node",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Academ-IA Node",
        "width": 900,
        "height": 650,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Academ-IA Node"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://acad-ia-78kiixzl.manus.space https://*.manus.space http://localhost:11434; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2025 Academ-IA. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "Local AI Worker for Academ-IA",
    "longDescription": "Academ-IA Node runs local AI models on your company server, ensuring complete data privacy while connecting to the Academ-IA platform.",
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English", "French", "Dutch", "German"],
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "entitlements": null,
      "providerShortName": null,
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "autostart": {
      "mobile": false,
      "desktop": false
    }
  }
}
